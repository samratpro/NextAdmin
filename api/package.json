{
  "name": "django-like-backend",
  "version": "1.0.0",
  "description": "Django-like framework with Fastify and TypeScript",
  "main": "dist/index.js",
  "engines": {
    "node": "20.x || 22.x || 24.x"
  },
  "scripts": {
    "preinstall": "node ../scripts/check-node.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/cli/migrate.ts",
    "makemigrations": "tsx src/cli/makemigrations.ts",
    "create-user": "tsx src/cli/create_user.ts",
    "createsuperuser": "tsx src/cli/create_user.ts",
    "startapp": "tsx src/cli/create_app.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "django",
    "fastify",
    "typescript",
    "framework"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.0.0",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^12.2.1",
    "mysql2": "^3.22.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.9",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mssql": "^9.1.11",
    "@types/node": "^20.11.28",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^4.1.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "vitest": "^4.1.2"
  },
  "type": "commonjs"
}
