# Server Configuration (API + Admin Backend)
PORT=8000
HOST=0.0.0.0
NODE_ENV=development

# Database
DB_PATH=./db.sqlite3

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (AES-256 for sensitive fields — must be exactly 32 characters)
ENCRYPTION_KEY=your-32-char-encryption-key-here!

# Email Configuration (REQUIRED for email verification)
# For Gmail: Enable 2FA and use App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourapp.com

# Frontend URLs
FRONTEND_URL=http://localhost:5000
ADMIN_URL=http://localhost:7000

# CORS — allow dashboard (5000) and admin (7000)
CORS_ORIGIN=http://localhost:5000,http://localhost:7000,http://localhost:3000

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Google Drive backup
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/admin/backup/drive/callback
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_SHARE_EMAIL=
